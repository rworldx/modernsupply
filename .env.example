# Copy to .env.local and fill in real values. Never commit the filled-in file.
#
# Prisma's CLI reads .env; the app runtime reads .env.local. DATABASE_URL is
# needed in .env for migrations to run.

# Postgres connection string — the same one in every environment, including
# local development. On Vercel it is injected automatically by the Prisma
# Postgres integration; copy that value here for local work.
# Format: postgres://USER:PASSWORD@HOST/DB?sslmode=require
#     or: prisma+postgres://accelerate.prisma-data.net/?api_key=...
DATABASE_URL=""

# Admin console credentials. Checked server-side only — never sent to the browser.
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# Signs the admin session cookie. Generate with: openssl rand -base64 32
# Required in production: the server refuses to start without it.
AUTH_SECRET=""

# Absolute site URL, used for metadata and Open Graph images. Optional.
NEXT_PUBLIC_SITE_URL="https://modernsupply.om"
